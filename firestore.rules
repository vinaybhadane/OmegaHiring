rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. QUIZZES: Sabko dikhne chahiye, par write sirf Teacher ko
    match /quizzes/{quizId} {
      allow read: if true; 
      allow write: if request.auth != null; 

      // Questions sub-collection
      match /questions/{qId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // 2. RESULTS: Guest student submit kar sake, lekin sirf Teacher/Admin dekh sake
    match /results/{resultId} {
      allow create: if true; 
      allow read: if request.auth != null; 
      allow update, delete: if request.auth != null && request.auth.token.email.lower() == "vinaybhadane06@gmail.com";
    }

    // 3. USERS: Khud ka data aur Admin access
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, update: if request.auth != null && request.auth.token.email.lower() == "vinaybhadane06@gmail.com";
    }
    
    // 4. CONTACT MESSAGES
    match /contactMessages/{msgId} {
      allow create: if true;
      allow read, delete: if request.auth != null;
    }

    // 5. HIRING APPLICATIONS: Logged-in users can read and write, Admin has full control
    match /hiring_applications/{docId} {
      allow read, write: if request.auth != null;
    }

    // 6. Default: Baki sab lock (Admin only)
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.email.lower() == "vinaybhadane06@gmail.com";
    }
  }
}